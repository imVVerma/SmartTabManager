{
  "manifest_version": 3,
  "name": "Smart Tab Manager",
  "version": "1.0",
  "description": "View, search, and save your tabs by session.",
  "permissions": ["tabs", "storage", "tabGroups"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Manager"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}